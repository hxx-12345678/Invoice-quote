{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "typeRoots": ["./node_modules/@types", "./types"]
  },
  "include": [
    "server.ts",
    "config/**/*.ts",
    "controllers/**/*.ts",
    "services/**/*.ts",
    "repositories/**/*.ts",
    "middleware/**/*.ts",
    "routes/**/*.ts",
    "utils/**/*.ts",
    "prisma/**/*.ts",
    "types/**/*.ts"
  ]
}
