# ==========================================
# IMPORTANT: Add these to your Render Environment Variables

# Database
DATABASE_URL=postgresql://invoice_bqty_user:i9kazVS8e4VnD0hIHDBCxPxOoJLRTPgM@dpg-d7nkt667r5hc73atfjag-a/invoice_bqty

# JWT Secrets (CHANGE THESE TO RANDOM VALUES)
JWT_SECRET=your-production-jwt-secret-change-this-to-random-value
JWT_REFRESH_SECRET=your-production-refresh-secret-change-this-to-random-value
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# Server Configuration
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://invoice-quote.vercel.app
BACKEND_URL=https://invoice-quote.onrender.com

# CORS - CRITICAL: Must allow your frontend domain
CORS_ORIGIN=https://invoice-quote.vercel.app

# Email Configuration (Brevo)
BREVO_API_KEY=your-brevo-api-key
EMAIL_FROM=noreply@invoiceflow.com
EMAIL_FROM_NAME=InvoiceFlow

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://invoice-quote.onrender.com/api/auth/google/callback

# SMTP Fallback
SMTP_HOST=smtp.mail.yahoo.com
SMTP_PORT=587
SMTP_USER=your-email@yahoo.com
SMTP_PASS=your-app-password

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
