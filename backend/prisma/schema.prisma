// ==========================================
// QUOTIQ - ENTERPRISE CPQ & BILLING SAAS
// Prisma Schema - PostgreSQL
// ==========================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// AUTHENTICATION & USERS
// ==========================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String       // Hashed password
  name      String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  businessProfiles BusinessProfile[]
  customers        Customer[]
  products         Product[]
  documents        Document[]
  payments         Payment[]
  quotes           Quote[]
  quoteVersions    QuoteVersion[]
  quoteActivities  QuoteActivityLog[]
  settings         UserSettings?
  apiTokens        ApiToken[]
  auditLogs        AuditLog[]

  @@index([email])
}

// ==========================================
// API TOKENS & SESSIONS
// ==========================================

model ApiToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  name      String
  expiresAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ==========================================
// AUDIT LOGGING
// ==========================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // 'CREATE', 'UPDATE', 'DELETE'
  entity    String   // 'INVOICE', 'QUOTE', 'CUSTOMER', etc.
  entityId  String
  oldData   Json?
  newData   Json?
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
}

// ==========================================
// BUSINESS PROFILE
// ==========================================

model BusinessProfile {
  id                  String   @id @default(cuid())
  userId              String
  businessType        String   // 'freelancer', 'sole_proprietor', 'partnership', 'llp', 'private_limited', 'enterprise'
  businessName        String
  legalName           String
  registrationNumber  String?
  taxId               String?  // GSTIN / VAT / EIN
  panNumber           String?
  country             String
  state               String
  city                String
  address             String
  pincode             String
  email               String
  phone               String
  website             String?
  logoUrl             String?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankDetails         BankDetail[]
  customers           Customer[]
  products            Product[]
  documents           Document[]
  quotes              Quote[]
  teams               Team[]
  invoiceTemplates    InvoiceTemplate[]

  @@unique([userId])
  @@index([userId])
  @@index([country])
}

// ==========================================
// BANK DETAILS (Normalized from BusinessProfile)
// ==========================================

model BankDetail {
  id                  String   @id @default(cuid())
  businessProfileId   String
  bankName            String
  accountNumber       String
  accountHolderName   String
  ifscCode            String?  // India
  swiftCode           String?  // International
  routingNumber       String?  // US
  iban                String?  // EU
  branch              String?
  isDefault           Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  businessProfile     BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@index([businessProfileId])
}

// ==========================================
// USER SETTINGS
// ==========================================

model UserSettings {
  id                    String   @id @default(cuid())
  userId                String   @unique
  currency              String   @default("INR")
  taxSystem             String   @default("GST") // 'GST', 'VAT', 'SALES_TAX', 'NONE'
  taxInclusive          Boolean  @default(false)
  defaultTaxRate        Float    @default(18)
  invoicePrefix         String   @default("INV")
  invoiceStartNumber    Int      @default(1)
  invoiceCurrentNumber  Int      @default(1)
  quotePrefix           String   @default("QT")
  quoteStartNumber      Int      @default(1)
  quoteCurrentNumber    Int      @default(1)
  timezone              String   @default("UTC")
  dateFormat            String   @default("DD/MM/YYYY")
  numberFormat          String   @default("en-US")
  defaultPaymentTerms   String   @default("net_30") // 'due_on_receipt', 'net_7', 'net_15', 'net_30', 'net_45', 'net_60', 'custom'
  defaultNotes          String?
  defaultTerms          String?
  emailNotifications    Boolean  @default(true)
  reminderDays          Int[]    @default([1, 7, 15]) // Days before due date for reminders
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==========================================
// CUSTOMER
// ==========================================

model Customer {
  id                  String   @id @default(cuid())
  userId              String
  businessProfileId   String
  name                String
  companyName         String?
  email               String
  phone               String?
  
  taxId               String?  // GSTIN/VAT/EIN
  creditLimit         Float?
  paymentTerms        String   @default("net_30")
  currency            String
  notes               String?
  tags                String[] @default([])
  isActive            Boolean  @default(true)
  
  // Statistics
  totalSpent          Float    @default(0)
  totalOutstanding    Float    @default(0)
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfile     BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  addresses           Address[]
  documents           Document[]
  quotes              Quote[]

  @@unique([businessProfileId, email])
  @@index([userId])
  @@index([businessProfileId])
  @@index([email])
}

// ==========================================
// ADDRESS (Normalized from Customer)
// ==========================================

model Address {
  id                  String   @id @default(cuid())
  customerId          String
  type                String   // 'billing', 'shipping'
  street              String
  city                String
  state               String
  country             String
  pincode             String
  isDefault           Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  customer            Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

// ==========================================
// PRODUCT / SERVICE
// ==========================================

model Product {
  id                  String   @id @default(cuid())
  userId              String
  businessProfileId   String
  name                String
  description         String?
  sku                 String?
  hsnCode             String?  // India - Harmonized System of Nomenclature
  sacCode             String?  // India - Services Accounting Code
  barcode             String?
  unitPrice           Float
  unit                String   // 'pcs', 'kg', 'g', 'ltr', 'ml', 'hrs', 'days', 'sqft', 'sqm', 'nos', 'box', 'unit'
  taxRate             Float    @default(0)
  taxType             String   @default("NONE") // 'CGST', 'SGST', 'IGST', 'VAT', 'SALES_TAX', 'NONE'
  category            String?
  isService           Boolean  @default(false)
  isActive            Boolean  @default(true)
  
  // Inventory (optional)
  stockQuantity       Int?
  lowStockThreshold   Int?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfile     BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  documentItems       DocumentItem[]
  quoteItems          QuoteItem[]

  @@index([userId])
  @@index([businessProfileId])
  @@index([sku])
}

// ==========================================
// DOCUMENT (Invoice/Proforma/Credit Note/Debit Note)
// ==========================================

model Document {
  id                  String   @id @default(cuid())
  userId              String
  businessProfileId   String
  customerId          String
  type                String   @default("invoice") // 'invoice', 'proforma', 'credit_note', 'debit_note'
  documentNumber      String   @unique
  issueDate           DateTime
  dueDate             DateTime
  currency            String
  exchangeRate        Float    @default(1)
  
  // Totals
  subtotal            Float    @default(0)
  discountTotal       Float    @default(0)
  taxTotal            Float    @default(0)
  grandTotal          Float    @default(0)
  
  // Payment Tracking
  amountPaid          Float    @default(0)
  amountDue           Float    @default(0)
  status              String   @default("draft") // 'draft', 'sent', 'paid', 'partially_paid', 'overdue', 'cancelled'
  
  notes               String?
  terms               String?
  referenceNumber     String?
  placeOfSupply       String?  // For GST
  
  // Proforma specific fields
  validityPeriod      Int?     // Days valid for proforma
  incoterms           String?  // International commercial terms
  deliveryTerms       String?  // Delivery conditions
  
  // Credit note specific fields
  reason              String?  // Reason for credit
  reasonCode          String?  // Standardized reason code
  
  // Attachments (file paths/URLs)
  attachments         String[] @default([])
  
  // Custom Fields (JSON)
  customFields        Json?
  
  // Timestamps
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  sentAt              DateTime?
  paidAt              DateTime?

  // Relations
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfile     BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  customer            Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items               DocumentItem[]
  payments            Payment[]
  taxBreakdowns       TaxBreakdown[]

  @@unique([businessProfileId, documentNumber])
  @@index([userId])
  @@index([businessProfileId])
  @@index([customerId])
  @@index([status])
  @@index([issueDate])
  @@index([dueDate])
}

// ==========================================
// DOCUMENT ITEMS (Line Items)
// ==========================================

model DocumentItem {
  id                  String   @id @default(cuid())
  documentId          String
  productId           String?
  name                String
  description         String?
  hsnCode             String?
  sacCode             String?
  quantity            Float
  unit                String
  unitPrice           Float
  discountPercent     Float    @default(0)
  discountAmount      Float    @default(0)
  taxType             String   @default("NONE")
  taxRate             Float    @default(0)
  taxAmount           Float    @default(0)
  totalBeforeTax      Float
  totalAfterTax       Float

  // Relations
  document            Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  product             Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([documentId])
  @@index([productId])
}

// ==========================================
// TAX BREAKDOWN (Normalized from Document/Quote)
// ==========================================

model TaxBreakdown {
  id                  String   @id @default(cuid())
  documentId          String?
  quoteId             String?
  taxType             String
  taxRate             Float
  taxableAmount       Float
  taxAmount           Float
  createdAt           DateTime @default(now())

  document            Document? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  quote               Quote?    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([quoteId])
}

// ==========================================
// PAYMENT
// ==========================================

model Payment {
  id                  String   @id @default(cuid())
  userId              String
  documentId          String
  amount              Float
  paymentMethod       String   // 'cash', 'upi', 'card', 'bank_transfer', 'cheque', 'paypal', 'stripe', 'other'
  transactionId       String?
  paymentDate         DateTime
  notes               String?
  status              String   @default("completed") // 'pending', 'completed', 'failed', 'refunded'
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document            Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([documentId])
  @@index([paymentDate])
}

// ==========================================
// QUOTE SYSTEM
// ==========================================

model Quote {
  id                    String   @id @default(cuid())
  userId                String
  businessProfileId     String
  customerId            String
  quoteNumber           String   @unique
  status                String   @default("draft") // 'draft', 'sent', 'viewed', 'approved', 'rejected', 'expired', 'converted'
  
  issueDate             DateTime
  expiryDate            DateTime
  currency              String
  exchangeRate          Float    @default(1)
  
  // Totals
  subtotal              Float    @default(0)
  discountTotal         Float    @default(0)
  taxTotal              Float    @default(0)
  grandTotal            Float    @default(0)
  
  notes                 String?
  terms                 String?
  referenceNumber       String?
  placeOfSupply         String?
  
  // Linked invoice after conversion
  convertedInvoiceId    String?
  
  // Version tracking
  versionNumber         Int      @default(1)
  
  // Public share token for client access
  shareToken            String   @unique
  isPubliclyShared      Boolean  @default(false)
  publicShareExpiresAt  DateTime?
  
  // Client approval/rejection
  clientComment         String?
  
  // Custom fields
  customFields          Json?
  
  // Activity & Timestamps
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  sentAt                DateTime?
  viewedAt              DateTime?
  approvedAt            DateTime?
  rejectedAt            DateTime?

  // Relations
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfile     BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  customer            Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items               QuoteItem[]
  versions            QuoteVersion[]
  activities          QuoteActivityLog[]
  taxBreakdowns       TaxBreakdown[]

  @@unique([businessProfileId, quoteNumber])
  @@index([userId])
  @@index([businessProfileId])
  @@index([customerId])
  @@index([status])
  @@index([shareToken])
  @@index([expiryDate])
}

// ==========================================
// QUOTE ITEMS
// ==========================================

model QuoteItem {
  id                  String   @id @default(cuid())
  quoteId             String
  productId           String?
  name                String
  description         String?
  hsnCode             String?
  sacCode             String?
  quantity            Float
  unit                String
  unitPrice           Float
  discountPercent     Float    @default(0)
  discountAmount      Float    @default(0)
  taxType             String   @default("NONE")
  taxRate             Float    @default(0)
  taxAmount           Float    @default(0)
  totalBeforeTax      Float
  totalAfterTax       Float
  isOptional          Boolean  @default(false) // Client can choose to include/exclude

  // Relations
  quote               Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product             Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([quoteId])
  @@index([productId])
}

// ==========================================
// QUOTE VERSION HISTORY
// ==========================================

model QuoteVersion {
  id                  String   @id @default(cuid())
  userId              String
  quoteId             String
  versionNumber       Int
  snapshotJson        String   // JSON.stringify of the entire Quote
  changeNote          String?
  createdAt           DateTime @default(now())

  // Relations
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quote               Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@unique([quoteId, versionNumber])
  @@index([userId])
  @@index([quoteId])
}

// ==========================================
// QUOTE ACTIVITY LOG
// ==========================================

model QuoteActivityLog {
  id                  String   @id @default(cuid())
  userId              String
  quoteId             String
  action              String   // 'created', 'edited', 'sent', 'viewed', 'approved', 'rejected', 'expired', 'converted', 'duplicated', 'comment'
  description         String
  metadata            Json?
  createdAt           DateTime @default(now())

  // Relations
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quote               Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quoteId])
  @@index([createdAt])
}

// ==========================================
// TEAM MANAGEMENT (Enterprise)
// ==========================================

model Team {
  id                  String   @id @default(cuid())
  businessProfileId   String
  name                String
  description         String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  businessProfile     BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  members             TeamMember[]

  @@index([businessProfileId])
}

// ==========================================
// TEAM MEMBER
// ==========================================

model TeamMember {
  id                  String   @id @default(cuid())
  teamId              String
  email               String
  name                String
  role                String   @default("staff") // 'owner', 'admin', 'accountant', 'staff'
  permissions         Json     // [{ resource: 'invoices', actions: ['create', 'read', 'update', 'delete'] }]
  isActive            Boolean  @default(true)
  joinedAt            DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  team                Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, email])
  @@index([teamId])
}

// ==========================================
// INVOICE TEMPLATES
// ==========================================

model InvoiceTemplate {
  id                  String   @id @default(cuid())
  businessProfileId   String
  name                String
  showLogo            Boolean  @default(true)
  showTaxBreakdown    Boolean  @default(true)
  showHsnSac          Boolean  @default(true)
  showQuantity        Boolean  @default(true)
  showUnit            Boolean  @default(true)
  showDiscount        Boolean  @default(true)
  showShippingAddress Boolean  @default(true)
  showBankDetails     Boolean  @default(true)
  showSignature       Boolean  @default(true)
  showQRCode          Boolean  @default(true)
  primaryColor        String   @default("#000000")
  accentColor         String   @default("#666666")
  fontFamily          String   @default("Inter")
  headerText          String?
  footerText          String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  businessProfile     BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@index([businessProfileId])
}
